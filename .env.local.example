# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for OTP email redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local auth bootstrap (used when no local-db exists yet)
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123456

# Deepseek AI assistant (learning mode)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Upstash Redis (required for Netlify production - AI quota & rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI usage limits
AI_MAX_QUESTIONS_PER_ITEM=5
AI_MAX_INPUT_CHARS=300
AI_MAX_OUTPUT_TOKENS=512
