# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# CloudBase Auth (email OTP)
NEXT_PUBLIC_TCB_ENV_ID=your-env-id
NEXT_PUBLIC_TCB_REGION=ap-shanghai
# CloudBase 控制台 → 身份认证 → API Key → Publishable Key（前端发验证码必需）
NEXT_PUBLIC_TCB_ACCESS_KEY=
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=
# Or use CloudBase API Key instead of SecretId/SecretKey:
# CLOUDBASE_APIKEY=

# Email access control (OR logic — any match allows login)
DNB_EMAIL_DOMAINS=dnb.com
DNB_EMAIL_WHITELIST=

# First admin bootstrap (optional — also works on first OTP login)
DNB_BOOTSTRAP_ADMIN_EMAIL=
DNB_BOOTSTRAP_ADMIN_UID=

# Deepseek AI assistant (learning mode)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Upstash Redis (required for Netlify production - DB, AI quota & rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI usage limits
AI_MAX_QUESTIONS_PER_ITEM=5
AI_MAX_INPUT_CHARS=300
AI_MAX_OUTPUT_TOKENS=512
